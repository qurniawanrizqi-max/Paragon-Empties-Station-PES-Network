# =========================================================
# Konfigurasi Koneksi Snowflake
# =========================================================
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=PLAYGROUND
SNOWFLAKE_SCHEMA=PLAYGROUND_RIZQI
SNOWFLAKE_ROLE=your_role

# =========================================================
# Mode Data
# =========================================================
# "mock"      -> pakai data sintetis (untuk development/demo tanpa akses Snowflake)
# "snowflake" -> query langsung ke Snowflake pakai kredensial di atas
# "csv"       -> baca dari file CSV lokal di drive Anda (lihat path di bawah)
DATA_MODE=csv

# =========================================================
# Path File CSV Lokal (dipakai HANYA saat DATA_MODE=csv)
# =========================================================
# Bisa path relatif (terhadap folder tempat `uvicorn` dijalankan) atau
# path absolut, contoh Windows: D:/Data/Paragon/sales.csv
# Nama KOLOM di dalam file CSV harus sama dengan nama kolom query Snowflake
# (lihat services/data_service.py bagian 3 "QUERY PER TABEL").
CSV_SALES_PATH=data/data_sales_order_pes.csv
CSV_FACILITIES_PATH=data/dno_facilties.csv
CSV_KEPADATAN_PATH=data/data_kepadatan_penduduk.csv
CSV_EMISSION_STANDARD_PATH=data/emission_standard_packaging_format.csv
CSV_MASA_HABIS_PAKAI_PATH=data/masa_habis_pakai_product_format.csv

# =========================================================
# Parameter Bisnis (bisa dioverride tanpa ubah kode)
# =========================================================
CARBON_PRICE_PER_TON=30000
EPR_FINE_PER_KG=5000
TARGET_EPR_PCT=0.20
PES_CAPEX_PER_MONTH=2000000
PES_OPEX_PER_MONTH=1500000
FUEL_EMISSION_FACTOR_KG_PER_LITER=2.68
FUEL_CONSUMPTION_KM_PER_LITER=8
TRUCK_CAPACITY_KG_PER_TRIP=500
COMPANY_EMISSION_CAP_KG=0
DEFAULT_LAG_BULAN=2
DENSITY_WEIGHT_FACTOR=0.15
LOCATION_MATCH_THRESHOLD=80
